{
    "[html][css][scss][vue][javascript][javascriptreact][typescript][typescriptreact]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "always"
        },
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json][jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "prettier.tabWidth": 4
    },
    "[toml]": {
        "editor.defaultFormatter": "tamasfe.even-better-toml"
    },
    "catppuccin.accentColor": "pink",
    "catppuccin.boldKeywords": false,
    "catppuccin.italicComments": false,
    "catppuccin.italicKeywords": false,
    "cSpell.userWords": [
        "Bencode",
        "bencodeparser",
        "catppuccin",
        "compat",
        "composables",
        "desaturated",
        "Domotz",
        "dotenv",
        "ecommerce",
        "esbenp",
        "firstname",
        "Gianmarco",
        "gianmarcoricciarelli",
        "gofmt",
        "goimports",
        "Gruvbox",
        "gsap",
        "Iosevka",
        "jsforce",
        "kpis",
        "licence",
        "linebreak",
        "Macchiato",
        "Modstamp",
        "Morty",
        "nmap",
        "packagejson",
        "Parens",
        "Perc",
        "pydantic",
        "Pylance",
        "resourcelocator",
        "Ricciarelli",
        "saleforce",
        "SERVERPORT",
        "sobject",
        "staticcheck",
        "Stringifier",
        "tamasfe",
        "tanstack",
        "taskstore",
        "Todos",
        "treedom",
        "trivago",
        "tseslint"
    ],
    "editor.autoClosingDelete": "always",
    "editor.detectIndentation": false,
    "editor.fontFamily": "Iosevka Regular",
    "editor.fontLigatures": true,
    "editor.fontSize": 13,
    "editor.formatOnSave": true,
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "eslint.debug": true,
    "eslint.format.enable": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "files.autoSave": "onFocusChange",
    "gitlens.views.branches.branches.layout": "list",
    "go.formatTool": "goimports",
    "go.lintOnSave": "file",
    "go.lintTool": "staticcheck",
    "go.testFlags": ["-race", "-shuffle=on"],
    "go.toolsManagement.autoUpdate": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "prettier.enableDebugLogs": true,
    "terminal.integrated.defaultProfile.osx": "fish",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "workbench.colorTheme": "Gruvbox Dark Medium",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.sideBar.location": "right",
    "workbench.startupEditor": "none"
}
